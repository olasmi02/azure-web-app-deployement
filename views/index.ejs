<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title><%= appName %></title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
      background: #0f1117;
      color: #e2e8f0;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .card {
      background: #1a1d27;
      border: 1px solid #2d3148;
      border-radius: 16px;
      padding: 48px 56px;
      max-width: 560px;
      width: 90%;
      text-align: center;
    }

    .badge {
      display: inline-block;
      background: #0078d4;
      color: #fff;
      font-size: 12px;
      font-weight: 600;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      padding: 4px 14px;
      border-radius: 20px;
      margin-bottom: 28px;
    }

    h1 {
      font-size: 2rem;
      font-weight: 700;
      margin-bottom: 12px;
      color: #f8fafc;
    }

    p.tagline {
      color: #94a3b8;
      font-size: 1rem;
      line-height: 1.6;
      margin-bottom: 36px;
    }

    .stats {
      display: flex;
      justify-content: center;
      gap: 32px;
      margin-bottom: 36px;
    }

    .stat {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 4px;
    }

    .stat-label {
      font-size: 11px;
      color: #64748b;
      text-transform: uppercase;
      letter-spacing: 0.06em;
    }

    .stat-value {
      font-size: 14px;
      font-weight: 600;
      color: #38bdf8;
    }

    .divider {
      border: none;
      border-top: 1px solid #2d3148;
      margin-bottom: 28px;
    }

    .env-tag {
      display: inline-block;
      background: #16213e;
      border: 1px solid #2d3148;
      color: #94a3b8;
      font-size: 13px;
      padding: 6px 18px;
      border-radius: 8px;
      font-family: monospace;
    }

    .env-tag span {
      color: #4ade80;
    }
  </style>
</head>
<body>
  <div class="card">
    <div class="badge">Azure App Service</div>
    <h1><%= appName %></h1>
    <p class="tagline">
      A Node.js Express application deployed to Azure App Service as part of a PaaS cloud deployment project.
    </p>

    <div class="stats">
      <div class="stat">
        <span class="stat-label">Runtime</span>
        <span class="stat-value">Node.js 20</span>
      </div>
      <div class="stat">
        <span class="stat-label">Framework</span>
        <span class="stat-value">Express</span>
      </div>
      <div class="stat">
        <span class="stat-label">Platform</span>
        <span class="stat-value">Azure PaaS</span>
      </div>
    </div>

    <hr class="divider"/>

    <div class="env-tag">APP_ENV = <span><%= env %></span></div>
  </div>
</body>
</html>
